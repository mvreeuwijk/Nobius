   "master_statement": "A tank is fitted with a manometer on the side as depicted. Find the position of the liquid surface in the manometer using absolute pressures, and using gauge pressures.<br>\\(S\\)(specific gravity)=$S, \\(h_{1}\\)=$h1 m.",
   "parts": [
      {
         "statement": "",
         "response": {
            "mode": "Numeric",
            "showUnits": true,
            "answer": {
               "num": "$h",
               "units": "cm"
            }
