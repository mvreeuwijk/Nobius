{
    "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Schema for SheetInfo.json file.",
        "type": "object",
        "properties": {
            "name": {"type": "string"},
            "number": {"type": "integer"},
            "description": {"type": "string"},
            "questions": {
                "type": "array",
                "items": {"type": "string"},
                "minItems": 1
            },
            "uid": {"type": "string"},
            "media_folder": {
                "type": "string",
                "pattern": "^\\S+$",
                "description": "Folder name for bundled media. Must contain no whitespace because Mobius rejects URL-encoded spaces in __BASE_URI__ paths."
            }
        },
        "required": [
            "name",
            "number",
            "description",
            "questions",
            "uid"
        ]
    }
