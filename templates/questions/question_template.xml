{% from 'layouts/default.html' import questionText as defaultQuestionText %}
{% from 'layouts/exam.html' import questionText as examQuestionText %}
{% from 'questions/part_template.xml' import render_part_standard %}

{% macro render_question_text(question) -%}
  {% if consts.LAYOUT_PROFILE == "exam" %}
    {{ examQuestionText(question) }}
  {% else %}
    {{ defaultQuestionText(question) }}
  {% endif %}
{%- endmacro %}

{% macro makeQuestion(question) %}
  <question uid="{{ question.uid }}" language="en">
    <mode>Inline</mode>
    <chainId><![CDATA[    ]]></chainId>
    <name>
      <![CDATA[ {{ question.title }} ]]>
    </name>
    <editing>useHTML</editing>
    {% if "algorithm" in question %}
      <algorithm>
        <![CDATA[ {{ question.algorithm }} ]]>
      </algorithm>
    {% endif %}
    <numberOfAttempts>1</numberOfAttempts>
    <numberOfAttemptsLeft>1</numberOfAttemptsLeft>
    <numberOfTryAnother>0</numberOfTryAnother>
    <numberOfTryAnotherLeft>0</numberOfTryAnotherLeft>
    <privacy>10</privacy>
    <allowRepublish>false</allowRepublish>
    <attributeAuthor>false</attributeAuthor>
    <modifiedIn>10.0</modifiedIn>
    <difficulty>0.0</difficulty>
    {# Render Question HTML below #}
    <text>
      {% filter indent(8, True) %}
        <![CDATA[ {{ render_question_text(question) }} ]]>
      {% endfilter %}
    </text>
    <width>0.0</width>
    <weighting>
      {%- for ra in question.response_areas -%}
        {{- ra.weighting -}}{{- "," if not loop.last else "" -}}
      {%- endfor -%}
    </weighting>
    <numbering>alpha</numbering>

    {# Data for each of the response areas marked <text> with their identifiers (<1>, <2>, ...) #}
    <parts>
      {% for response_area in question.response_areas %}
        {{ render_part_standard(response_area) }}
      {% endfor %}
    </parts>
  </question>
{% endmacro %}
